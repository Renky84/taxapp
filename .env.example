# === Core ===
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:pass@localhost:3306/tax_app
JWT_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:3000

# === Object Storage (required for receipts / exports) ===
S3_REGION=ap-northeast-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: S3-compatible (MinIO, Wasabi, etc.)
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# === LLM (optional: enables receipt auto-extraction) ===
# If not set, you can still upload receipts and enter expenses manually.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# === Email (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@example.com
OWNER_NOTIFICATION_EMAIL=
