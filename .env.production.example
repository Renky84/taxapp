# Database
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME

# Session / auth
JWT_SECRET=change-this-in-production
TWO_FACTOR_PENDING_SECRET=change-this-too
TOTP_SETUP_SECRET=change-this-too
APP_URL=https://your-app.example.com

# SMTP for login verification / email 2FA
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-account@example.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Storage (choose one)
# 1) Local fallback for development only
#    Leave all S3_* blank and uploads will go to local_uploads/

# 2) S3 / R2 / compatible object storage
S3_BUCKET=
S3_REGION=ap-northeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Optional built-in storage proxy
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
